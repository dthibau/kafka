{
  "type": "record",
  "namespace": "fr.plb.csfle",
  "name": "Customer",
  "fields": [
    { "name": "id",         "type": "string" },
    { "name": "firstName",  "type": "string" },
    { "name": "lastName",   "type": "string" },
    { "name": "email",      "type": "string", "confluent:tags": ["PII"] },
    { "name": "creditCard", "type": "string", "confluent:tags": ["PII"] },
    { "name": "country",    "type": "string" }
  ]
}
